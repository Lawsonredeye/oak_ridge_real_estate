{
    "version": 2,
    "builds": [
        {
            "src": "**/*.html",
            "use": "@vercel/static"
        },
        {
            "src": "css/**",
            "use": "@vercel/static"
        },
        {
            "src": "js/**",
            "use": "@vercel/static"
        },
        {
            "src": "images/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/properties",
            "dest": "/properties.html"
        },
        {
            "src": "/about",
            "dest": "/about.html"
        },
        {
            "src": "/contact",
            "dest": "/contact.html"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}